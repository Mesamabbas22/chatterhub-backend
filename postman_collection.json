{
  "info": {
    "_postman_id": "7d5c49e2-ef3d-4f84-9f9e-chatappapis",
    "name": "Chat App Laravel API",
    "description": "Postman collection for the Laravel JWT chat app API. Set base_url to your local API URL, for example http://127.0.0.1:8000/api. Login/register automatically saves the JWT token. User search saves the first matched user as receiver_id, received requests save conversation_request_id, and approve saves conversation_id.",
